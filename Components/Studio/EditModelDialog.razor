@using CheapFurniturePlanner.Services

@inject ModelAuthoringService ModelAuthoringService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Edit model</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField T="string" Label="Code" Value="@Code" Disabled="true" />
            <MudTextField T="string" Label="Name" @bind-Value="_name" Required="true" />
            <MudTextField T="string" Label="Collection (optional)" @bind-Value="_collection" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitAsync">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string Code { get; set; } = string.Empty;

    [Parameter]
    public string Name { get; set; } = string.Empty;

    [Parameter]
    public string? Collection { get; set; }

    private string _name = string.Empty;
    private string? _collection;

    protected override void OnInitialized()
    {
        _name = Name;
        _collection = Collection;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            Snackbar.Add("Name is required.", Severity.Warning);
            return;
        }

        try
        {
            await ModelAuthoringService.RenameAsync(Code, _name, _collection);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
