@using CheapFurniturePlanner.Catalogue
@using CheapFurniturePlanner.Domain.Masters
@using CheapFurniturePlanner.Services
@inject AuthoringCatalogueStore AuthoringCatalogueStore
@inject MasterAuthoringService MasterAuthoringService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => AddAsync())">
        Add operation
    </MudButton>
    <MudTable Items="@_operations" Hover="true" Striped="true" Dense="true" Elevation="2" T="Operation">
        <HeaderContent>
            <MudTh>Code</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Unit cost</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Code">@context.Code</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Unit cost">@context.UnitCost</MudTd>
            <MudTd DataLabel="Actions">
                <MudStack Row="true" Spacing="1">
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => EditAsync(context))">Edit</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => DeleteAsync(context))">Delete</MudButton>
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudStack>

@code {
    private List<Operation> _operations = [];

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync() => _operations = (await AuthoringCatalogueStore.LoadAsync()).Operations;

    private async Task AddAsync()
    {
        var parameters = new DialogParameters<OperationDialog> { { d => d.SubmitLabel, "Add" } };
        var dialogRef = await DialogService.ShowAsync<OperationDialog>("Add operation", parameters);
        await ApplyAsync(dialogRef, operation => MasterAuthoringService.AddOperationAsync(operation));
    }

    private async Task EditAsync(Operation existing)
    {
        var parameters = new DialogParameters<OperationDialog> { { d => d.Operation, existing }, { d => d.SubmitLabel, "Save" } };
        var dialogRef = await DialogService.ShowAsync<OperationDialog>("Edit operation", parameters);
        await ApplyAsync(dialogRef, operation => MasterAuthoringService.UpdateOperationAsync(existing.Code, operation));
    }

    private async Task DeleteAsync(Operation existing)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync("Delete operation", $"Delete '{existing.Code}'?", yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) { return; }
        try
        {
            await MasterAuthoringService.DeleteOperationAsync(existing.Code);
        }
        catch (Exception ex) when (ex is InvalidOperationException or MasterReferencedException)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await ReloadAsync();
    }

    private async Task ApplyAsync(IDialogReference dialogRef, Func<Operation, Task> apply)
    {
        var dialogResult = await dialogRef.Result;
        if (dialogResult is null || dialogResult.Canceled || dialogResult.Data is not Operation operation) { return; }
        try
        {
            await apply(operation);
        }
        catch (Exception ex) when (ex is InvalidOperationException or MasterReferencedException)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await ReloadAsync();
    }
}
