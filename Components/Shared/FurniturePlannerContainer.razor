@using CheapFurniturePlanner.ViewModels
@using CheapFurniturePlanner.Models
@using Microsoft.AspNetCore.Components.Web
@using System.Globalization
@using System.Text
@using System.Diagnostics
@using Microsoft.JSInterop
@using MudBlazor

@inject IJSRuntime JS
@inject ISnackbar ToastService

<div class="furniture-planner-container">
    <!-- Toolbar -->
    <MudStack Row="true" Spacing="2" Class="toolbar mb-3" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h6">@RoomPlan.Name</MudText>

        <MudSpacer />

        <MudToggleIconButton @bind-Toggled="ShowGrid"
                             Icon="@Icons.Material.Filled.GridOn"
                             ToggledIcon="@Icons.Material.Filled.GridOff"
                             Title="Toggle Grid" />

        <MudToggleIconButton @bind-Toggled="PreventOverlap"
                             Icon="@Icons.Material.Filled.Block"
                             ToggledIcon="@Icons.Material.Filled.CheckBoxOutlineBlank"
                             Title="Toggle Overlap Prevention" />

        <MudToggleIconButton @bind-Toggled="EnableSnapping"
                             Icon="@Icons.Material.Filled.CenterFocusStrong"
                             ToggledIcon="@Icons.Material.Filled.CenterFocusWeak"
                             Title="Toggle Snapping" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenFurnitureDialog">
            Add Furniture
        </MudButton>

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.Clear"
                   OnClick="ClearAll"
                   Disabled="@(!SelectedFurniture.Any())">
            Clear All
        </MudButton>
    </MudStack>

    <!-- Room Plan Canvas -->
    <div id="furniture-planner"
         class="room-plan @(_isDragging ? "dragging" : "")"
         style="width:@(FloorPlanWidth)px;height:@(FloorPlanHeight)px;"
         @ref="_floorPlanElement"
         @onkeydown="HandleKeyDown"
         tabindex="0">

        <!-- Grid Overlay -->
        @if (ShowGrid)
        {
            <div class="grid-overlay" style="position: absolute; width: 100%; height: 100%; pointer-events: none; z-index: 1;">
                @for (int i = 0; i <= FloorPlanWidth; i += GridSize)
                {
                    <div class="grid-line vertical" style="position: absolute; left: @(i)px; top: 0; width: 1px; height: 100%; background-color: rgba(200,200,200,0.5);">
                        <div style="position: absolute; left: 2px; top: 0; font-size: 8px; color: #999;">@i</div>
                    </div>
                }
                @for (int i = 0; i <= FloorPlanHeight; i += GridSize)
                {
                    <div class="grid-line horizontal" style="position: absolute; left: 0; top: @(i)px; width: 100%; height: 1px; background-color: rgba(200,200,200,0.5);">
                        <div style="position: absolute; left: 0; top: 2px; font-size: 8px; color: #999;">@i</div>
                    </div>
                }
            </div>
        }

        <!-- Furniture Items -->
        @foreach (var item in SelectedFurniture)
        {
            // Calculate dimensions based on rotation
            bool isRotated = ((int)Math.Round(item.Rotation / 90) % 2) == 1; // 90° or 270°
            double displayWidth = isRotated ? item.FurnitureLength.GetValueOrDefault() : item.FurnitureWidth.GetValueOrDefault();
            double displayHeight = isRotated ? item.FurnitureWidth.GetValueOrDefault() : item.FurnitureLength.GetValueOrDefault();

            // Position and size the container
            StringBuilder styling = new StringBuilder($"position: absolute; left:{item.X}px; top:{item.Y}px; width:{displayWidth}px; height:{displayHeight}px; background-color: #ffffff; z-index: 3;");

            StringBuilder classstring = new StringBuilder("furniture-item");
            if (item == SelectedItem)
            {
                classstring.Append(" selected");
            }
            if (item.IsDragging)
            {
                classstring.Append(" dragging");
            }
            if (item.GroupID != null)
            {
                classstring.Append(" grouped");
            }
            if (item.SnapEdge != null)
            {
                classstring.Append(" snapped");
            }
            if (_isDragging && SelectedItem != null && SelectedItem.GroupID != null && item.GroupID == SelectedItem.GroupID && item != SelectedItem)
            {
                classstring.Append(" group-dragging");
            }
            classstring.Append($" rotation-{item.Rotation}");

            <MudPaper @key="item.UIId"
                      id="@($"fi-{item.UIId}")"
                      Class="@classstring.ToString()"
                      Elevation="@(item.GroupID != null ? 3 : 1)"
                      style="@styling.ToString()"
                      @onmousedown="@((MouseEventArgs e) => StartDragging(item, e))"
                      @ontouchstart="@((TouchEventArgs e) => OnTouchStart(item, e))"
                      @onclick="@(() => SelectItem(item))">

                <!-- Furniture Content -->
                <div class="furniture-content" style="width: 100%; height: 100%; position: relative;">

                    <!-- Image if available -->
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <div class="image-rotator" style="transform: rotate(@(item.Rotation)deg);">
                            <img src="@item.ImageUrl"
                                 alt="@item.Name"
                                 style="width: @(displayWidth)px; height: @(displayHeight)px;" />
                        </div>
                    }
                    else
                    {
                        <!-- Default furniture representation -->
                        <div class="furniture-placeholder"
                             style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background-color: #f5f5f5; border: 2px dashed #ccc;">
                            <MudText Typo="Typo.caption" Align="Align.Center">
                                @item.Name<br />
                                @item.Code
                            </MudText>
                        </div>
                    }

                    <!-- Dimension indicators -->
                    @if (item == SelectedItem || item.IsSelected)
                    {
                        <!-- Width line -->
                        <div class="width-line" style="position: absolute; bottom: -15px; left: 0; width: 100%; height: 1px; background-color: #1976d2; pointer-events: none;">
                            <div class="width-text" style="position: absolute; left: 50%; transform: translateX(-50%); top: 2px;">
                                @displayWidth cm
                            </div>
                        </div>

                        <!-- Height line -->
                        <div class="height-line" style="position: absolute; right: -15px; top: 0; width: 1px; height: 100%; background-color: #1976d2; pointer-events: none;">
                            <div class="height-text" style="position: absolute; top: 50%; transform: translateY(-50%) rotate(-90deg); left: 2px; transform-origin: left center;">
                                @displayHeight cm
                            </div>
                        </div>
                    }

                    <!-- Action buttons for selected item -->
                    @if (item == SelectedItem)
                    {
                        <div class="action-buttons" style="position: absolute; top: -35px; right: 0; display: flex; gap: 4px;">
                            <MudIconButton Icon="@Icons.Material.Filled.RotateRight"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => RotateItem(item, 90))"
                                           Title="Rotate 90°" />

                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                           Size="Size.Small"
                                           Color="Color.Secondary"
                                           OnClick="@(() => DuplicateItem(item))"
                                           Title="Duplicate" />

                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => DeleteFurniture(item.UIId))"
                                           Title="Delete" />
                        </div>
                    }
                </div>
            </MudPaper>
        }
    </div>

    <!-- Information Panel -->
    @if (SelectedItem != null)
    {
        <MudCard Class="mt-3">
            <MudCardContent>
                <MudText Typo="Typo.h6">@SelectedItem.Name</MudText>
                <MudText Typo="Typo.body2" Class="mb-2">@SelectedItem.Code</MudText>

                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <MudText Typo="Typo.caption">Position</MudText>
                        <MudText>X: @SelectedItem.X.ToString("F0") cm, Y: @SelectedItem.Y.ToString("F0") cm</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudText Typo="Typo.caption">Dimensions</MudText>
                        <MudText>@SelectedItem.FurnitureWidth × @SelectedItem.FurnitureLength × @SelectedItem.FurnitureHeight cm</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudText Typo="Typo.caption">Rotation</MudText>
                        <MudText>@SelectedItem.Rotation°</MudText>
                    </MudItem>
                    @if (SelectedItem.Price.HasValue)
                    {
                        <MudItem xs="12" sm="6" md="3">
                            <MudText Typo="Typo.caption">Price</MudText>
                            <MudText>@SelectedItem.Price.Value.ToString("C")</MudText>
                        </MudItem>
                    }
                    @if (SelectedItem.GroupID.HasValue)
                    {
                        <MudItem xs="12" sm="6" md="3">
                            <MudText Typo="Typo.caption">Group</MudText>
                            <MudText>Group @SelectedItem.GroupID</MudText>
                        </MudItem>
                    }
                </MudGrid>
            </MudCardContent>
        </MudCard>
    }
</div>

<!-- Furniture Selection Dialog -->
<MudDialog @bind-Visible="_furnitureDialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Large })">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-3">Select Furniture</MudText>

        <!-- Furniture Type Filter -->
        <MudSelect T="FurnitureType?"
                   @bind-Value="_selectedType"
                   Label="Filter by Type"
                   Clearable="true"
                   Class="mb-3">
            @foreach (FurnitureType type in Enum.GetValues<FurnitureType>())
            {
                <MudSelectItem T="FurnitureType?" Value="type">@type</MudSelectItem>
            }
        </MudSelect>

        <!-- Furniture Grid -->
        <div style="max-height: 400px; overflow-y: auto;">
            <MudGrid>
                @foreach (var furniture in FilteredFurniture)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Class="furniture-card" Style="cursor: pointer;" @onclick="@(() => AddFurnitureAndCloseDialog(furniture))">
                            <MudCardContent>
                                @if (!string.IsNullOrEmpty(furniture.ImageUrl))
                                {
                                    <MudImage Src="@furniture.ImageUrl" Alt="@furniture.Name" Height="100" ObjectFit="ObjectFit.Cover" Class="mb-2" />
                                }
                                else
                                {
                                    <div style="height: 100px; background-color: #f5f5f5; display: flex; align-items: center; justify-content: center; margin-bottom: 8px;">
                                        <MudIcon Icon="@GetFurnitureIcon(furniture.Type)" Size="Size.Large" />
                                    </div>
                                }

                                <MudText Typo="Typo.subtitle2">@furniture.Name</MudText>
                                <MudText Typo="Typo.caption">@furniture.Code</MudText>
                                <MudText Typo="Typo.body2" Class="mt-1">
                                    @furniture.Width × @furniture.Length cm
                                </MudText>
                                @if (furniture.Price.HasValue)
                                {
                                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">
                                        @furniture.Price.Value.ToString("C")
                                    </MudText>
                                }
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _furnitureDialogOpen = false)">Close</MudButton>
    </DialogActions>
</MudDialog>

@implements IAsyncDisposable

@code {
    [Parameter] public RoomPlanViewModel RoomPlan { get; set; } = new();
    [Parameter] public List<FurniturePlannerViewModel> SelectedFurniture { get; set; } = new();
    [Parameter] public List<FurnitureCatalogViewModel> AvailableFurniture { get; set; } = new();
    [Parameter] public EventCallback<List<FurniturePlannerViewModel>> SelectedFurnitureChanged { get; set; }
    [Parameter] public EventCallback<FurniturePlannerViewModel> OnFurnitureAdded { get; set; }
    [Parameter] public EventCallback<FurniturePlannerViewModel> OnFurnitureRemoved { get; set; }
    [Parameter] public EventCallback<FurniturePlannerViewModel> OnFurnitureModified { get; set; }

    // Planner settings
    public int FloorPlanWidth => (int)RoomPlan.Width;
    public int FloorPlanHeight => (int)RoomPlan.Height;
    public int GridSize => RoomPlan.GridSize;
    public bool ShowGrid { get; set; } = true;
    public bool PreventOverlap { get; set; } = true;
    public bool EnableSnapping { get; set; } = true;

    // Constants
    private const double SnapDistance = 8.0;
    private const double CollisionTolerance = 0.1;

    // State management
    private FurniturePlannerViewModel? SelectedItem { get; set; }
    private bool _isDragging;
    private bool _jsHandlingDrag; // Suppresses Blazor re-renders during JS drag
    private double _dragStartX;
    private double _dragStartY;
    private ElementReference _floorPlanElement;

    // Cached bounds — fetched ONCE, reused across drags
    private DOMRect? _cachedBounds;

    // JS interop
    private DotNetObjectReference<FurniturePlannerContainer>? _dotNetRef;

    // Group tracking
    private int _nextGroupId = 1;

    // Touch state
    private CancellationTokenSource? _touchDelayCts;

    // Dialog state
    private bool _furnitureDialogOpen;
    private FurnitureType? _selectedType;

    private IEnumerable<FurnitureCatalogViewModel> FilteredFurniture =>
        _selectedType.HasValue
            ? AvailableFurniture.Where(f => f.Type == _selectedType.Value && f.IsActive)
            : AvailableFurniture.Where(f => f.IsActive);

    // Suppress Blazor re-renders while JS is handling drag
    protected override bool ShouldRender() => !_jsHandlingDrag;

    protected override void OnParametersSet()
    {
        ShowGrid = RoomPlan.ShowGrid;
        PreventOverlap = RoomPlan.PreventOverlap;
        EnableSnapping = RoomPlan.EnableSnapping;

        // Init _nextGroupId from max existing GroupID
        int maxGroupId = SelectedFurniture
            .Where(f => f.GroupID.HasValue)
            .Select(f => f.GroupID!.Value)
            .DefaultIfEmpty(0)
            .Max();
        _nextGroupId = maxGroupId + 1;

        // Invalidate cached bounds when room dimensions change
        _cachedBounds = null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
        }

        if (_cachedBounds == null)
        {
            _cachedBounds = await JS.InvokeAsync<DOMRect>("getBoundingClientRect", _floorPlanElement);
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("furnitureDrag.stop");
        }
        catch
        {
            // Component may be disposed after circuit is gone
        }
        _touchDelayCts?.Cancel();
        _touchDelayCts?.Dispose();
        _dotNetRef?.Dispose();
    }

    // ========== Furniture Icon Helper ==========
    private string GetFurnitureIcon(FurnitureType type) => type switch
    {
        FurnitureType.Sofa => Icons.Material.Filled.Chair,
        FurnitureType.Chair => Icons.Material.Filled.Chair,
        FurnitureType.Table => Icons.Material.Filled.TableRestaurant,
        FurnitureType.Bed => Icons.Material.Filled.Bed,
        FurnitureType.Wardrobe => Icons.Material.Filled.Checkroom,
        FurnitureType.Desk => Icons.Material.Filled.Desk,
        FurnitureType.DiningTable => Icons.Material.Filled.TableRestaurant,
        FurnitureType.CoffeeTable => Icons.Material.Filled.TableBar,
        _ => Icons.Material.Filled.Chair
    };

    // ========== Dialog & Add ==========
    private void OpenFurnitureDialog()
    {
        _furnitureDialogOpen = true;
        _selectedType = null;
    }

    private async Task AddFurniture(FurnitureCatalogViewModel furniture)
    {
        try
        {
            int newId = SelectedFurniture.Any() ? SelectedFurniture.Max(f => f.UIId) + 1 : 1;
            var plannerItem = furniture.ToPlannerViewModel();
            plannerItem.UIId = newId;

            // Position the new item at the top right corner with margin
            double width = plannerItem.FurnitureWidth.GetValueOrDefault();
            double height = plannerItem.FurnitureLength.GetValueOrDefault();

            // Make sure the item fits within the floor plan
            width = Math.Min(width, FloorPlanWidth - 40);
            height = Math.Min(height, FloorPlanHeight - 40);

            // Position at top-right with margin
            plannerItem.X = FloorPlanWidth - width - 20;
            plannerItem.Y = 20;

            SelectedFurniture.Add(plannerItem);
            SelectedItem = plannerItem;

            await OnFurnitureAdded.InvokeAsync(plannerItem);
            await SelectedFurnitureChanged.InvokeAsync(SelectedFurniture);

            ToastService.Add($"Added {plannerItem.Name} to room plan", Severity.Success);
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"Error in AddFurniture: {ex.Message}");
            ToastService.Add("Error adding furniture", Severity.Error);
        }
    }

    private async Task AddFurnitureAndCloseDialog(FurnitureCatalogViewModel furniture)
    {
        await AddFurniture(furniture);
        _furnitureDialogOpen = false;
    }

    // ========== Selection ==========
    private void SelectItem(FurniturePlannerViewModel item)
    {
        SelectedItem = item;

        // Clear selection state from all items
        foreach (var f in SelectedFurniture)
        {
            f.IsSelected = false;
        }

        item.IsSelected = true;
    }

    // ========== Client-Side Drag (JS handles mousemove, single SignalR call on drop) ==========
    private async Task StartDragging(FurniturePlannerViewModel item, MouseEventArgs mouseArgs)
    {
        if (_isDragging || _dotNetRef == null) return;

        SelectItem(item);

        // Re-fetch bounds at drag start — a cached rect goes stale after window resize/scroll
        _cachedBounds = await JS.InvokeAsync<DOMRect>("getBoundingClientRect", _floorPlanElement);

        // Calculate offset: where the mouse grabbed relative to item origin
        item.OffsetX = (mouseArgs.ClientX - _cachedBounds.Left) - item.X;
        item.OffsetY = (mouseArgs.ClientY - _cachedBounds.Top) - item.Y;

        _isDragging = true;
        item.IsDragging = true;
        _dragStartX = item.X;
        _dragStartY = item.Y;

        // Calculate display dimensions for the primary item
        bool isRotated = ((int)Math.Round(item.Rotation / 90) % 2) == 1;
        double primaryWidth = isRotated ? item.FurnitureLength.GetValueOrDefault() : item.FurnitureWidth.GetValueOrDefault();
        double primaryHeight = isRotated ? item.FurnitureWidth.GetValueOrDefault() : item.FurnitureLength.GetValueOrDefault();

        // Build group member info for JS
        object[]? groupMembers = null;
        if (item.GroupID.HasValue)
        {
            var members = SelectedFurniture.Where(f => f.GroupID == item.GroupID && f.UIId != item.UIId).ToList();
            groupMembers = members.Select(m =>
            {
                m.InitialGroupX = m.X;
                m.InitialGroupY = m.Y;
                bool mRotated = ((int)Math.Round(m.Rotation / 90) % 2) == 1;
                return (object)new
                {
                    id = $"fi-{m.UIId}",
                    initialX = m.X,
                    initialY = m.Y,
                    width = mRotated ? m.FurnitureLength.GetValueOrDefault() : m.FurnitureWidth.GetValueOrDefault(),
                    height = mRotated ? m.FurnitureWidth.GetValueOrDefault() : m.FurnitureLength.GetValueOrDefault()
                };
            }).ToArray();
            item.InitialGroupX = item.X;
            item.InitialGroupY = item.Y;
        }

        // Blazor renders here (adds "dragging" class) before the await
        // Then JS takes over — zero SignalR during drag
        _jsHandlingDrag = true;
        await JS.InvokeVoidAsync("furnitureDrag.start", _dotNetRef, new
        {
            primaryId = $"fi-{item.UIId}",
            offsetX = item.OffsetX,
            offsetY = item.OffsetY,
            boundsLeft = _cachedBounds.Left,
            boundsTop = _cachedBounds.Top,
            floorWidth = FloorPlanWidth,
            floorHeight = FloorPlanHeight,
            primaryWidth,
            primaryHeight,
            initialX = item.X,
            initialY = item.Y,
            groupMembers = groupMembers ?? Array.Empty<object>()
        });
    }

    [JSInvokable]
    public void OnClientDragEnd(double finalX, double finalY)
    {
        _jsHandlingDrag = false;

        if (!_isDragging || SelectedItem == null) return;

        _isDragging = false;
        SelectedItem.IsDragging = false;

        // Apply final position from JS
        if (SelectedItem.GroupID.HasValue)
        {
            double deltaX = finalX - SelectedItem.InitialGroupX;
            double deltaY = finalY - SelectedItem.InitialGroupY;

            // Apply delta to all group members
            foreach (var member in SelectedFurniture.Where(f => f.GroupID == SelectedItem.GroupID))
            {
                member.X = member.InitialGroupX + deltaX;
                member.Y = member.InitialGroupY + deltaY;
            }
        }
        else
        {
            SelectedItem.X = finalX;
            SelectedItem.Y = finalY;
        }

        // Snap on drop
        if (EnableSnapping)
        {
            ApplySnapping(SelectedItem);
        }

        // Check boundaries
        EnsureWithinBounds(SelectedItem);

        // Overlap check — revert if needed
        if (PreventOverlap && HasOverlap(SelectedItem))
        {
            if (SelectedItem.GroupID.HasValue)
            {
                foreach (var groupMember in SelectedFurniture.Where(f => f.GroupID == SelectedItem.GroupID))
                {
                    groupMember.X = groupMember.InitialGroupX;
                    groupMember.Y = groupMember.InitialGroupY;
                }
            }
            else
            {
                SelectedItem.X = _dragStartX;
                SelectedItem.Y = _dragStartY;
            }
            ToastService.Add("Cannot place furniture here - it overlaps with another item", Severity.Warning);
        }

        // Clear snap state
        foreach (var furnitureItem in SelectedFurniture)
        {
            furnitureItem.SnapEdge = null;
            furnitureItem.SnapTargetUIId = null;
        }

        StateHasChanged();
    }

    // ========== Touch Support ==========
    private async Task OnTouchStart(FurniturePlannerViewModel item, TouchEventArgs touchArgs)
    {
        if (_isDragging || _dotNetRef == null || touchArgs.Touches.Length == 0) return;

        var firstTouch = touchArgs.Touches[0];

        SelectItem(item);

        // 150ms delay before initiating drag (prevents accidental drags on touch)
        _touchDelayCts?.Cancel();
        _touchDelayCts?.Dispose();
        _touchDelayCts = new CancellationTokenSource();
        var token = _touchDelayCts.Token;

        try
        {
            await Task.Delay(150, token);
            if (token.IsCancellationRequested) return;

            // Re-fetch bounds at drag start — a cached rect goes stale after window resize/scroll
            _cachedBounds = await JS.InvokeAsync<DOMRect>("getBoundingClientRect", _floorPlanElement);

            // Calculate offset
            item.OffsetX = (firstTouch.ClientX - _cachedBounds.Left) - item.X;
            item.OffsetY = (firstTouch.ClientY - _cachedBounds.Top) - item.Y;

            _isDragging = true;
            item.IsDragging = true;
            _dragStartX = item.X;
            _dragStartY = item.Y;

            bool isRotated = ((int)Math.Round(item.Rotation / 90) % 2) == 1;
            double primaryWidth = isRotated ? item.FurnitureLength.GetValueOrDefault() : item.FurnitureWidth.GetValueOrDefault();
            double primaryHeight = isRotated ? item.FurnitureWidth.GetValueOrDefault() : item.FurnitureLength.GetValueOrDefault();

            object[]? groupMembers = null;
            if (item.GroupID.HasValue)
            {
                var members = SelectedFurniture.Where(f => f.GroupID == item.GroupID && f.UIId != item.UIId).ToList();
                groupMembers = members.Select(m =>
                {
                    m.InitialGroupX = m.X;
                    m.InitialGroupY = m.Y;
                    bool mRotated = ((int)Math.Round(m.Rotation / 90) % 2) == 1;
                    return (object)new
                    {
                        id = $"fi-{m.UIId}",
                        initialX = m.X,
                        initialY = m.Y,
                        width = mRotated ? m.FurnitureLength.GetValueOrDefault() : m.FurnitureWidth.GetValueOrDefault(),
                        height = mRotated ? m.FurnitureWidth.GetValueOrDefault() : m.FurnitureLength.GetValueOrDefault()
                    };
                }).ToArray();
                item.InitialGroupX = item.X;
                item.InitialGroupY = item.Y;
            }

            _jsHandlingDrag = true;
            StateHasChanged();

            await JS.InvokeVoidAsync("furnitureDrag.start", _dotNetRef, new
            {
                primaryId = $"fi-{item.UIId}",
                offsetX = item.OffsetX,
                offsetY = item.OffsetY,
                boundsLeft = _cachedBounds.Left,
                boundsTop = _cachedBounds.Top,
                floorWidth = FloorPlanWidth,
                floorHeight = FloorPlanHeight,
                primaryWidth,
                primaryHeight,
                initialX = item.X,
                initialY = item.Y,
                groupMembers = groupMembers ?? Array.Empty<object>()
            });
        }
        catch (TaskCanceledException)
        {
            // Touch ended before delay — not a drag
        }
    }

    // ========== Edge-Based Snapping ==========
    private void ApplySnapping(FurniturePlannerViewModel item)
    {
        // Clear previous snap state
        item.SnapEdge = null;
        item.SnapTargetUIId = null;

        double bestScore = double.MaxValue;
        string? bestEdge = null;
        int? bestTargetUIId = null;
        double bestSnapX = item.X;
        double bestSnapY = item.Y;

        bool isRotatedItem = ((int)Math.Round(item.Rotation / 90) % 2) == 1;
        double itemWidth = isRotatedItem ? item.FurnitureLength.GetValueOrDefault() : item.FurnitureWidth.GetValueOrDefault();
        double itemHeight = isRotatedItem ? item.FurnitureWidth.GetValueOrDefault() : item.FurnitureLength.GetValueOrDefault();

        foreach (var other in SelectedFurniture)
        {
            if (other.UIId == item.UIId) continue;
            // Skip same-group items for snapping
            if (item.GroupID.HasValue && item.GroupID == other.GroupID) continue;

            bool isRotatedOther = ((int)Math.Round(other.Rotation / 90) % 2) == 1;
            double otherWidth = isRotatedOther ? other.FurnitureLength.GetValueOrDefault() : other.FurnitureWidth.GetValueOrDefault();
            double otherHeight = isRotatedOther ? other.FurnitureWidth.GetValueOrDefault() : other.FurnitureLength.GetValueOrDefault();

            // Try 4 edge snap positions
            TryEdgeSnap(item, other, "right", item.X + itemWidth, other.X, itemWidth, itemHeight, otherWidth, otherHeight,
                ref bestScore, ref bestEdge, ref bestTargetUIId, ref bestSnapX, ref bestSnapY);

            TryEdgeSnap(item, other, "left", item.X, other.X + otherWidth, itemWidth, itemHeight, otherWidth, otherHeight,
                ref bestScore, ref bestEdge, ref bestTargetUIId, ref bestSnapX, ref bestSnapY);

            TryEdgeSnap(item, other, "bottom", item.Y + itemHeight, other.Y, itemWidth, itemHeight, otherWidth, otherHeight,
                ref bestScore, ref bestEdge, ref bestTargetUIId, ref bestSnapX, ref bestSnapY);

            TryEdgeSnap(item, other, "top", item.Y, other.Y + otherHeight, itemWidth, itemHeight, otherWidth, otherHeight,
                ref bestScore, ref bestEdge, ref bestTargetUIId, ref bestSnapX, ref bestSnapY);
        }

        if (bestEdge != null)
        {
            item.X = bestSnapX;
            item.Y = bestSnapY;
            item.SnapEdge = bestEdge;
            item.SnapTargetUIId = bestTargetUIId;
        }
    }

    private void TryEdgeSnap(
        FurniturePlannerViewModel item, FurniturePlannerViewModel other,
        string edge, double itemEdge, double otherEdge,
        double itemWidth, double itemHeight, double otherWidth, double otherHeight,
        ref double bestScore, ref string? bestEdge, ref int? bestTargetUIId,
        ref double bestSnapX, ref double bestSnapY)
    {
        double distance = Math.Abs(itemEdge - otherEdge);
        if (distance > SnapDistance) return;

        // Calculate adjacency ratio (how much items overlap on the perpendicular axis)
        double adjacencyRatio;
        double spanDistance;
        double candidateX = item.X;
        double candidateY = item.Y;

        if (edge is "left" or "right")
        {
            double overlapStart = Math.Max(item.Y, other.Y);
            double overlapEnd = Math.Min(item.Y + itemHeight, other.Y + otherHeight);
            double overlapLength = Math.Max(0, overlapEnd - overlapStart);
            double minHeight = Math.Min(itemHeight, otherHeight);
            adjacencyRatio = minHeight > 0 ? overlapLength / minHeight : 0;
            spanDistance = Math.Abs((item.Y + itemHeight / 2) - (other.Y + otherHeight / 2));

            if (edge == "right")
                candidateX = other.X - itemWidth;
            else
                candidateX = other.X + otherWidth;
        }
        else
        {
            double overlapStart = Math.Max(item.X, other.X);
            double overlapEnd = Math.Min(item.X + itemWidth, other.X + otherWidth);
            double overlapLength = Math.Max(0, overlapEnd - overlapStart);
            double minWidth = Math.Min(itemWidth, otherWidth);
            adjacencyRatio = minWidth > 0 ? overlapLength / minWidth : 0;
            spanDistance = Math.Abs((item.X + itemWidth / 2) - (other.X + otherWidth / 2));

            if (edge == "bottom")
                candidateY = other.Y - itemHeight;
            else
                candidateY = other.Y + otherHeight;
        }

        // Weighted score: closer distance + more adjacency = better snap
        double score = distance * 2.0 - adjacencyRatio * 8.0 + spanDistance * 0.5;

        if (score < bestScore)
        {
            bestScore = score;
            bestEdge = edge;
            bestTargetUIId = other.UIId;
            bestSnapX = candidateX;
            bestSnapY = candidateY;

            // Apply alignment after snap
            ApplyAlignmentAfterSnap(item, other, edge, itemWidth, itemHeight, otherWidth, otherHeight,
                ref bestSnapX, ref bestSnapY);
        }
    }

    private void ApplyAlignmentAfterSnap(
        FurniturePlannerViewModel item, FurniturePlannerViewModel other,
        string edge, double itemWidth, double itemHeight, double otherWidth, double otherHeight,
        ref double snapX, ref double snapY)
    {
        // Aligns the perpendicular axis after an edge snap
        if (edge is "left" or "right")
        {
            if (Math.Abs(item.Y - other.Y) < SnapDistance)
                snapY = other.Y;
            else if (Math.Abs((item.Y + itemHeight) - (other.Y + otherHeight)) < SnapDistance)
                snapY = other.Y + otherHeight - itemHeight;
            else if (Math.Abs((item.Y + itemHeight / 2) - (other.Y + otherHeight / 2)) < SnapDistance)
                snapY = other.Y + (otherHeight - itemHeight) / 2;
        }
        else
        {
            if (Math.Abs(item.X - other.X) < SnapDistance)
                snapX = other.X;
            else if (Math.Abs((item.X + itemWidth) - (other.X + otherWidth)) < SnapDistance)
                snapX = other.X + otherWidth - itemWidth;
            else if (Math.Abs((item.X + itemWidth / 2) - (other.X + otherWidth / 2)) < SnapDistance)
                snapX = other.X + (otherWidth - itemWidth) / 2;
        }
    }

    // ========== Center-Maintaining Rotation ==========
    private async Task RotateItem(FurniturePlannerViewModel item, double degrees)
    {
        bool wasRotated = ((int)Math.Round(item.Rotation / 90) % 2) == 1;
        double oldWidth = wasRotated ? item.FurnitureLength.GetValueOrDefault() : item.FurnitureWidth.GetValueOrDefault();
        double oldHeight = wasRotated ? item.FurnitureWidth.GetValueOrDefault() : item.FurnitureLength.GetValueOrDefault();

        // Calculate center before rotation
        double centerX = item.X + oldWidth / 2;
        double centerY = item.Y + oldHeight / 2;

        // Apply rotation
        item.Rotation = (item.Rotation + degrees) % 360;
        if (item.Rotation < 0) item.Rotation += 360;

        bool isRotated = ((int)Math.Round(item.Rotation / 90) % 2) == 1;
        double newWidth = isRotated ? item.FurnitureLength.GetValueOrDefault() : item.FurnitureWidth.GetValueOrDefault();
        double newHeight = isRotated ? item.FurnitureWidth.GetValueOrDefault() : item.FurnitureLength.GetValueOrDefault();

        // Recalculate position from center with new dimensions
        item.X = centerX - newWidth / 2;
        item.Y = centerY - newHeight / 2;

        EnsureWithinBounds(item);

        // Collision check after rotation — revert if overlap
        if (PreventOverlap && HasOverlap(item))
        {
            item.Rotation = (item.Rotation - degrees) % 360;
            if (item.Rotation < 0) item.Rotation += 360;
            item.X = centerX - oldWidth / 2;
            item.Y = centerY - oldHeight / 2;
            ToastService.Add("Cannot rotate - would overlap with another item", Severity.Warning);
            StateHasChanged();
            return;
        }

        await OnFurnitureModified.InvokeAsync(item);
        StateHasChanged();
    }

    private void RotateGroupItems(FurniturePlannerViewModel pivot, double degrees)
    {
        if (!pivot.GroupID.HasValue) return;

        var groupItems = SelectedFurniture.Where(f => f.GroupID == pivot.GroupID).ToList();

        // Calculate pivot center
        bool pivotRotated = ((int)Math.Round(pivot.Rotation / 90) % 2) == 1;
        double pivotWidth = pivotRotated ? pivot.FurnitureLength.GetValueOrDefault() : pivot.FurnitureWidth.GetValueOrDefault();
        double pivotHeight = pivotRotated ? pivot.FurnitureWidth.GetValueOrDefault() : pivot.FurnitureLength.GetValueOrDefault();
        double pivotCenterX = pivot.X + pivotWidth / 2;
        double pivotCenterY = pivot.Y + pivotHeight / 2;

        double radians = degrees * Math.PI / 180.0;
        double cosA = Math.Cos(radians);
        double sinA = Math.Sin(radians);

        // Store original positions for rollback
        var originals = groupItems.Select(f => new { f.UIId, f.X, f.Y, f.Rotation }).ToList();

        foreach (var member in groupItems)
        {
            bool memberRotated = ((int)Math.Round(member.Rotation / 90) % 2) == 1;
            double memberWidth = memberRotated ? member.FurnitureLength.GetValueOrDefault() : member.FurnitureWidth.GetValueOrDefault();
            double memberHeight = memberRotated ? member.FurnitureWidth.GetValueOrDefault() : member.FurnitureLength.GetValueOrDefault();

            double memberCenterX = member.X + memberWidth / 2;
            double memberCenterY = member.Y + memberHeight / 2;

            // 2D rotation matrix around pivot center
            double relX = memberCenterX - pivotCenterX;
            double relY = memberCenterY - pivotCenterY;
            double newCenterX = pivotCenterX + (relX * cosA - relY * sinA);
            double newCenterY = pivotCenterY + (relX * sinA + relY * cosA);

            // Apply individual rotation
            member.Rotation = (member.Rotation + degrees) % 360;
            if (member.Rotation < 0) member.Rotation += 360;

            bool newMemberRotated = ((int)Math.Round(member.Rotation / 90) % 2) == 1;
            double newMemberWidth = newMemberRotated ? member.FurnitureLength.GetValueOrDefault() : member.FurnitureWidth.GetValueOrDefault();
            double newMemberHeight = newMemberRotated ? member.FurnitureWidth.GetValueOrDefault() : member.FurnitureLength.GetValueOrDefault();

            member.X = newCenterX - newMemberWidth / 2;
            member.Y = newCenterY - newMemberHeight / 2;
        }

        // Validate all members are within bounds and no collisions with non-group items
        bool invalid = groupItems.Any(m =>
        {
            EnsureWithinBounds(m);
            return PreventOverlap && SelectedFurniture.Any(other =>
                other.UIId != m.UIId &&
                (!m.GroupID.HasValue || other.GroupID != m.GroupID) &&
                ItemsOverlap(m, other));
        });

        if (invalid)
        {
            foreach (var orig in originals)
            {
                var member = groupItems.First(f => f.UIId == orig.UIId);
                member.X = orig.X;
                member.Y = orig.Y;
                member.Rotation = orig.Rotation;
            }
            ToastService.Add("Cannot rotate group - would cause overlap or go out of bounds", Severity.Warning);
        }
    }

    // ========== Group System ==========
    private void CreateOrJoinGroup(FurniturePlannerViewModel item1, FurniturePlannerViewModel item2)
    {
        if (item1.GroupID.HasValue && item2.GroupID.HasValue)
        {
            int targetGroupId = item1.GroupID.Value;
            int sourceGroupId = item2.GroupID.Value;
            foreach (var member in SelectedFurniture.Where(f => f.GroupID == sourceGroupId))
            {
                member.GroupID = targetGroupId;
            }
        }
        else if (item1.GroupID.HasValue)
        {
            item2.GroupID = item1.GroupID;
        }
        else if (item2.GroupID.HasValue)
        {
            item1.GroupID = item2.GroupID;
        }
        else
        {
            int newGroupId = _nextGroupId++;
            item1.GroupID = newGroupId;
            item2.GroupID = newGroupId;
        }
    }

    private void MoveGroupWithCSharp(FurniturePlannerViewModel primary, double newX, double newY)
    {
        if (!primary.GroupID.HasValue)
        {
            primary.X = newX;
            primary.Y = newY;
            EnsureWithinBounds(primary);
            return;
        }

        double deltaX = newX - primary.InitialGroupX;
        double deltaY = newY - primary.InitialGroupY;

        var groupMembers = SelectedFurniture.Where(f => f.GroupID == primary.GroupID).ToList();

        // Pre-check ALL members for bounds
        foreach (var member in groupMembers)
        {
            double candidateX = member.InitialGroupX + deltaX;
            double candidateY = member.InitialGroupY + deltaY;

            bool isRotatedMember = ((int)Math.Round(member.Rotation / 90) % 2) == 1;
            double memberWidth = isRotatedMember ? member.FurnitureLength.GetValueOrDefault() : member.FurnitureWidth.GetValueOrDefault();
            double memberHeight = isRotatedMember ? member.FurnitureWidth.GetValueOrDefault() : member.FurnitureLength.GetValueOrDefault();

            if (candidateX < 0 || candidateY < 0 ||
                candidateX + memberWidth > FloorPlanWidth ||
                candidateY + memberHeight > FloorPlanHeight)
            {
                return; // Don't apply ANY movement
            }
        }

        // Pre-check collisions with non-group items
        if (PreventOverlap)
        {
            foreach (var member in groupMembers)
            {
                double candidateX = member.InitialGroupX + deltaX;
                double candidateY = member.InitialGroupY + deltaY;

                if (WouldOverlap(member, candidateX, candidateY, groupMembers))
                {
                    return;
                }
            }
        }

        // All checks passed — apply ALL positions atomically
        foreach (var member in groupMembers)
        {
            member.X = member.InitialGroupX + deltaX;
            member.Y = member.InitialGroupY + deltaY;
        }
    }

    private bool WouldOverlap(FurniturePlannerViewModel item, double candidateX, double candidateY,
        List<FurniturePlannerViewModel> excludeGroup)
    {
        bool isRotatedItem = ((int)Math.Round(item.Rotation / 90) % 2) == 1;
        double itemWidth = isRotatedItem ? item.FurnitureLength.GetValueOrDefault() : item.FurnitureWidth.GetValueOrDefault();
        double itemHeight = isRotatedItem ? item.FurnitureWidth.GetValueOrDefault() : item.FurnitureLength.GetValueOrDefault();

        foreach (var other in SelectedFurniture)
        {
            if (other.UIId == item.UIId) continue;
            if (excludeGroup.Any(g => g.UIId == other.UIId)) continue;

            bool isRotatedOther = ((int)Math.Round(other.Rotation / 90) % 2) == 1;
            double otherWidth = isRotatedOther ? other.FurnitureLength.GetValueOrDefault() : other.FurnitureWidth.GetValueOrDefault();
            double otherHeight = isRotatedOther ? other.FurnitureWidth.GetValueOrDefault() : other.FurnitureLength.GetValueOrDefault();

            bool overlaps = !(candidateX + itemWidth <= other.X + CollisionTolerance ||
                              other.X + otherWidth <= candidateX + CollisionTolerance ||
                              candidateY + itemHeight <= other.Y + CollisionTolerance ||
                              other.Y + otherHeight <= candidateY + CollisionTolerance);

            if (overlaps) return true;
        }

        return false;
    }

    private void UngroupItem(FurniturePlannerViewModel item)
    {
        if (!item.GroupID.HasValue) return;

        int groupId = item.GroupID.Value;
        item.GroupID = null;

        // Disband if 1 or fewer remaining
        var remaining = SelectedFurniture.Where(f => f.GroupID == groupId).ToList();
        if (remaining.Count <= 1)
        {
            foreach (var member in remaining)
            {
                member.GroupID = null;
            }
        }

        ToastService.Add($"Ungrouped {item.Name}", Severity.Info);
        StateHasChanged();
    }

    // ========== Keyboard Shortcuts ==========
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (SelectedItem == null) return;

        switch (e.Code)
        {
            case "KeyR":
                if (e.ShiftKey && SelectedItem.GroupID.HasValue)
                {
                    RotateGroupItems(SelectedItem, 90);
                }
                else
                {
                    await RotateItem(SelectedItem, 90);
                }
                break;
            case "Delete":
                await DeleteFurniture(SelectedItem.UIId);
                break;
            case "KeyG":
                UngroupItem(SelectedItem);
                break;
        }
    }

    // ========== Duplicate / Delete / Clear ==========
    private async Task DuplicateItem(FurniturePlannerViewModel item)
    {
        try
        {
            int newId = SelectedFurniture.Max(f => f.UIId) + 1;
            var duplicate = item.PlannerClone();
            duplicate.UIId = newId;
            duplicate.X = item.X + 30;
            duplicate.Y = item.Y + 30;

            SelectedFurniture.Add(duplicate);
            SelectedItem = duplicate;

            await OnFurnitureAdded.InvokeAsync(duplicate);
            await SelectedFurnitureChanged.InvokeAsync(SelectedFurniture);

            ToastService.Add($"Duplicated {item.Name}", Severity.Success);
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"Error duplicating furniture: {ex.Message}");
            ToastService.Add("Error duplicating furniture", Severity.Error);
        }
    }

    private async Task DeleteFurniture(int uiId)
    {
        var item = SelectedFurniture.FirstOrDefault(f => f.UIId == uiId);
        if (item != null)
        {
            SelectedFurniture.Remove(item);
            if (SelectedItem == item)
            {
                SelectedItem = null;
            }

            await OnFurnitureRemoved.InvokeAsync(item);
            await SelectedFurnitureChanged.InvokeAsync(SelectedFurniture);

            ToastService.Add($"Removed {item.Name}", Severity.Info);
        }
    }

    private async Task ClearAll()
    {
        if (SelectedFurniture.Any())
        {
            SelectedFurniture.Clear();
            SelectedItem = null;

            await SelectedFurnitureChanged.InvokeAsync(SelectedFurniture);
            ToastService.Add("Cleared all furniture", Severity.Info);
        }
    }

    // ========== Bounds & Collision ==========
    private void EnsureWithinBounds(FurniturePlannerViewModel item)
    {
        bool isRotated = ((int)Math.Round(item.Rotation / 90) % 2) == 1;
        double width = isRotated ? item.FurnitureLength.GetValueOrDefault() : item.FurnitureWidth.GetValueOrDefault();
        double height = isRotated ? item.FurnitureWidth.GetValueOrDefault() : item.FurnitureLength.GetValueOrDefault();

        item.X = Math.Max(0, Math.Min(item.X, FloorPlanWidth - width));
        item.Y = Math.Max(0, Math.Min(item.Y, FloorPlanHeight - height));
    }

    private bool HasOverlap(FurniturePlannerViewModel item)
    {
        if (!PreventOverlap) return false;

        return SelectedFurniture.Any(other =>
            other.UIId != item.UIId &&
            !(item.GroupID.HasValue && item.GroupID == other.GroupID) &&
            ItemsOverlap(item, other));
    }

    private bool ItemsOverlap(FurniturePlannerViewModel item1, FurniturePlannerViewModel item2)
    {
        bool isRotated1 = ((int)Math.Round(item1.Rotation / 90) % 2) == 1;
        bool isRotated2 = ((int)Math.Round(item2.Rotation / 90) % 2) == 1;

        double width1 = isRotated1 ? item1.FurnitureLength.GetValueOrDefault() : item1.FurnitureWidth.GetValueOrDefault();
        double height1 = isRotated1 ? item1.FurnitureWidth.GetValueOrDefault() : item1.FurnitureLength.GetValueOrDefault();

        double width2 = isRotated2 ? item2.FurnitureLength.GetValueOrDefault() : item2.FurnitureWidth.GetValueOrDefault();
        double height2 = isRotated2 ? item2.FurnitureWidth.GetValueOrDefault() : item2.FurnitureLength.GetValueOrDefault();

        return !(item1.X + width1 <= item2.X + CollisionTolerance ||
                 item2.X + width2 <= item1.X + CollisionTolerance ||
                 item1.Y + height1 <= item2.Y + CollisionTolerance ||
                 item2.Y + height2 <= item1.Y + CollisionTolerance);
    }
}