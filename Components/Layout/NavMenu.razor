@using Microsoft.AspNetCore.Components.Routing
@using MudBlazor
@inject NavigationManager Navigation

<MudNavMenu>
    @* Home/planner/catalogue links: gated to any authenticated user (bare AuthorizeView), same
       reach as the bare [Authorize] on Home/PlannerPage/FurnitureCatalog/RoomPlans themselves. *@
    <AuthorizeView>
        <!-- Home -->
        <MudNavLink Href="/"
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.Home">
            Home
        </MudNavLink>

        <MudDivider Class="my-2" />

        <!-- Room Plans -->
        <MudNavGroup Text="Room Plans"
                     Icon="@Icons.Material.Filled.MeetingRoom"
                     Expanded="true">
            <MudNavLink Href="/room-plans"
                        Icon="@Icons.Material.Filled.List">
                All Plans
            </MudNavLink>
            <MudNavLink Href="/room-plans/new"
                        Icon="@Icons.Material.Filled.Add">
                New Plan
            </MudNavLink>
            @* <MudNavLink Href="/room-plans/templates"
                        Icon="@Icons.Material.Filled.ContentCopy">
                Templates
            </MudNavLink> *@
        </MudNavGroup>

        <!-- Furniture Catalog -->
        <MudNavGroup Text="Furniture"
                     Icon="@Icons.Material.Filled.Chair"
                     Expanded="false">
            <MudNavLink Href="/furniture/catalog"
                        Icon="@Icons.Material.Filled.ViewModule">
                Catalog
            </MudNavLink>
            <MudNavLink Href="/furniture/add"
                        Icon="@Icons.Material.Filled.Add">
                Add Furniture
            </MudNavLink>
            @* <MudNavLink Href="/furniture/popular"
                        Icon="@Icons.Material.Filled.TrendingUp">
                Popular Items
            </MudNavLink>
            <MudNavLink Href="/furniture/statistics"
                        Icon="@Icons.Material.Filled.Analytics">
                Statistics
            </MudNavLink> *@
        </MudNavGroup>
    </AuthorizeView>

    @* <MudDivider Class="my-2" />

    <!-- Tools -->
    <MudNavGroup Text="Tools"
                 Icon="@Icons.Material.Filled.Build"
                 Expanded="false">
        <MudNavLink Href="/tools/export"
                    Icon="@Icons.Material.Filled.Download">
            Export Plans
        </MudNavLink>
        <MudNavLink Href="/tools/import"
                    Icon="@Icons.Material.Filled.Upload">
            Import Data
        </MudNavLink>
        <MudNavLink Href="/tools/backup"
                    Icon="@Icons.Material.Filled.Backup">
            Backup
        </MudNavLink>
    </MudNavGroup>

    <MudDivider Class="my-2" /> *@

    @* Business links: Admin or Office only, matching the [Authorize(Roles = Roles.AdminOrOffice)]
       on each destination page. *@
    <AuthorizeView Roles="@Roles.AdminOrOffice">
        <MudNavLink Href="/studio"
                    Icon="@Icons.Material.Filled.Tag">
            Studio
        </MudNavLink>

        <MudNavLink Href="/studio/prices"
                    Icon="@Icons.Material.Filled.PriceChange">
            Prices
        </MudNavLink>

        <MudNavLink Href="/studio/masters"
                    Icon="@Icons.Material.Filled.AttachMoney">
            Masters
        </MudNavLink>

        <MudNavLink Href="/studio/articles"
                    Icon="@Icons.Material.Filled.Inventory2">
            Articles
        </MudNavLink>

        <MudNavLink Href="/orders"
                    Icon="@Icons.Material.Filled.ShoppingCart">
            Orders
        </MudNavLink>

        <MudNavLink Href="/parties"
                    Icon="@Icons.Material.Filled.People">
            Parties
        </MudNavLink>
    </AuthorizeView>

    @* Service: any authenticated user - mechanics work their tickets here too. *@
    <AuthorizeView>
        <MudNavLink Href="/service"
                    Icon="@Icons.Material.Filled.Handyman">
            Service
        </MudNavLink>
    </AuthorizeView>

    @* Dock screens: Admin, Office or Warehouse. *@
    <AuthorizeView Roles="@Roles.WarehouseStaff">
        <MudNavLink Href="/receiving"
                    Icon="@Icons.Material.Filled.Warehouse">
            Receiving
        </MudNavLink>
        <MudNavLink Href="/trips"
                    Icon="@Icons.Material.Filled.LocalShipping">
            Trips
        </MudNavLink>
    </AuthorizeView>

    @* Admin only. *@
    <AuthorizeView Roles="@Roles.Admin">
        <MudNavLink Href="/users"
                    Icon="@Icons.Material.Filled.ManageAccounts">
            Users
        </MudNavLink>
    </AuthorizeView>

    @* Help & About: not gated, same reach as the unattributed (anonymous-accessible) pages. *@
    <MudNavLink Href="/help"
                Icon="@Icons.Material.Filled.Help">
        Help
    </MudNavLink>

    <MudNavLink Href="/about"
                Icon="@Icons.Material.Filled.Info">
        About
    </MudNavLink>
</MudNavMenu>

