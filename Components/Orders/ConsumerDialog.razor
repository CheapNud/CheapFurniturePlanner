<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField T="string" Label="Name" @bind-Value="_name" Required="true" />
            <MudTextField T="string" Label="Contact" @bind-Value="_contact" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">@SubmitLabel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Consumer? Consumer { get; set; }

    [Parameter]
    public string SubmitLabel { get; set; } = "Save";

    private string _name = string.Empty;
    private string _contact = string.Empty;

    protected override void OnInitialized()
    {
        if (Consumer is not null)
        {
            _name = Consumer.Name;
            _contact = Consumer.Contact ?? string.Empty;
        }
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok(new Consumer { Name = _name.Trim(), Contact = _contact.Trim() }));
}
