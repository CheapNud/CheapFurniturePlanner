@page "/modellenkamer"
@using CheapFurniturePlanner.Domain.Catalog

@inject ModelPublishService ModelPublishService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Modellenkamer - Cheap Furniture Planner</PageTitle>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h5">Modellenkamer</MudText>
        <MudAlert Severity="Severity.Info">Only released (Active) models appear in the catalogue and planner.</MudAlert>
    </MudStack>
</MudPaper>

@if (_models is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTable Items="@_models" Hover="true" Striped="true" Dense="true" Elevation="2">
        <HeaderContent>
            <MudTh>Code</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>State</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Code">@context.Code</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="State">
                <MudChip T="bool" Size="Size.Small" Color="@StateColor(context.State)">@context.State</MudChip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudStack Row="true" Spacing="2">
                    <MudButton Size="Size.Small"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@(context.State != TradeItemState.Draft)"
                               OnClick="@(() => ReleaseAsync(context.Code))">
                        Release
                    </MudButton>
                    <MudButton Size="Size.Small"
                               Variant="Variant.Outlined"
                               Color="Color.Error"
                               Disabled="@(context.State != TradeItemState.Active)"
                               OnClick="@(() => DiscontinueAsync(context.Code))">
                        Discontinue
                    </MudButton>
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private IReadOnlyList<AuthoringModel>? _models;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _models = await ModelPublishService.GetAuthoringModelsAsync();
    }

    private async Task ReleaseAsync(string modelCode)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Release model",
            $"This publishes '{modelCode}' - it becomes visible in the catalogue and planner. Continue?",
            yesText: "Release",
            cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        try
        {
            await ModelPublishService.ReleaseAsync(modelCode);
            Snackbar.Add($"Model '{modelCode}' released.", Severity.Success);
            await ReloadAsync();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task DiscontinueAsync(string modelCode)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Discontinue model",
            $"'{modelCode}' will be discontinued and removed from the catalogue and planner. Continue?",
            yesText: "Discontinue",
            cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        try
        {
            await ModelPublishService.DiscontinueAsync(modelCode);
            Snackbar.Add($"Model '{modelCode}' discontinued.", Severity.Success);
            await ReloadAsync();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private static Color StateColor(TradeItemState state) => state switch
    {
        TradeItemState.Active => Color.Success,
        TradeItemState.Discontinued => Color.Error,
        _ => Color.Default
    };
}
