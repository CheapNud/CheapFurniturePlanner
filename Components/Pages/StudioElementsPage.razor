@page "/studio/{ModelCode}/elements"
@using CheapFurniturePlanner.Catalogue
@using CheapFurniturePlanner.Components.Studio
@using CheapFurniturePlanner.Domain.Catalog
@using CheapFurniturePlanner.Services

@inject AuthoringCatalogueStore AuthoringCatalogueStore
@inject ModelPublishService ModelPublishService
@inject ElementAuthoringService ElementAuthoringService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Elements - @ModelCode - Cheap Furniture Planner</PageTitle>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h5">Elements — @ModelCode</MudText>
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       Href="/studio">
                Back to models
            </MudButton>
        </MudStack>

        @if (_model is not null)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">@_model.Name</MudText>

            @if (_state != TradeItemState.Draft)
            {
                <MudAlert Severity="Severity.Warning">frozen — model is @_state</MudAlert>
            }
            else
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="@(() => AddElementAsync())">
                    Add element
                </MudButton>
            }
        }
    </MudStack>
</MudPaper>

@if (_notFound)
{
    <MudAlert Severity="Severity.Error">Model '@ModelCode' not found.</MudAlert>
}
else if (_model is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTable Items="@_model.Elements" Hover="true" Striped="true" Dense="true" Elevation="2">
        <HeaderContent>
            <MudTh>Code</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Width</MudTh>
            <MudTh>Depth</MudTh>
            <MudTh>Height</MudTh>
            <MudTh>Transport</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Code">@context.Code</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Width">@context.Width</MudTd>
            <MudTd DataLabel="Depth">@context.Depth</MudTd>
            <MudTd DataLabel="Height">@context.Height</MudTd>
            <MudTd DataLabel="Transport">@context.TransportUnits</MudTd>
            <MudTd DataLabel="Actions">
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                                   Size="Size.Small"
                                   Disabled="@(_state != TradeItemState.Draft || IsFirst(context))"
                                   OnClick="@(() => MoveAsync(context.Code, -1))" />
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward"
                                   Size="Size.Small"
                                   Disabled="@(_state != TradeItemState.Draft || IsLast(context))"
                                   OnClick="@(() => MoveAsync(context.Code, 1))" />
                    <MudButton Size="Size.Small"
                               Variant="Variant.Outlined"
                               Color="Color.Default"
                               Disabled="@(_state != TradeItemState.Draft)"
                               OnClick="@(() => EditElementAsync(context))">
                        Edit
                    </MudButton>
                    <MudButton Size="Size.Small"
                               Variant="Variant.Outlined"
                               Color="Color.Error"
                               Disabled="@(_state != TradeItemState.Draft)"
                               OnClick="@(() => DeleteElementAsync(context))">
                        Delete
                    </MudButton>
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Parameter]
    public string ModelCode { get; set; } = string.Empty;

    private FurnitureModel? _model;
    private bool _notFound;
    private TradeItemState _state;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _model = await AuthoringCatalogueStore.LoadModelAsync(ModelCode);
        if (_model is null)
        {
            _notFound = true;
            return;
        }
        _state = await ModelPublishService.GetStateAsync(ModelCode);
    }

    private bool IsFirst(Element element) => _model is not null && _model.Elements.IndexOf(element) == 0;

    private bool IsLast(Element element) => _model is not null && _model.Elements.IndexOf(element) == _model.Elements.Count - 1;

    private async Task AddElementAsync()
    {
        var parameters = new DialogParameters<ElementDialog>
        {
            { dialog => dialog.SubmitLabel, "Add" }
        };
        var dialogRef = await DialogService.ShowAsync<ElementDialog>("Add element", parameters);
        var dialogResult = await dialogRef.Result;
        if (dialogResult is null || dialogResult.Canceled || dialogResult.Data is not Element element)
        {
            return;
        }
        try
        {
            await ElementAuthoringService.AddElementAsync(ModelCode, element);
            await ReloadAsync();
        }
        catch (Exception ex) when (ex is InvalidOperationException or StructureFrozenException)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task EditElementAsync(Element existing)
    {
        var parameters = new DialogParameters<ElementDialog>
        {
            { dialog => dialog.Element, existing },
            { dialog => dialog.SubmitLabel, "Save" }
        };
        var dialogRef = await DialogService.ShowAsync<ElementDialog>("Edit element", parameters);
        var dialogResult = await dialogRef.Result;
        if (dialogResult is null || dialogResult.Canceled || dialogResult.Data is not Element element)
        {
            return;
        }
        try
        {
            await ElementAuthoringService.UpdateElementAsync(ModelCode, existing.Code, element);
            await ReloadAsync();
        }
        catch (Exception ex) when (ex is InvalidOperationException or StructureFrozenException)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task DeleteElementAsync(Element existing)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete element",
            $"Delete '{existing.Code}'? Any named variants for this element are also removed.",
            yesText: "Delete",
            cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }
        try
        {
            await ElementAuthoringService.RemoveElementAsync(ModelCode, existing.Code);
            await ReloadAsync();
        }
        catch (Exception ex) when (ex is InvalidOperationException or StructureFrozenException)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task MoveAsync(string elementCode, int delta)
    {
        if (_model is null)
        {
            return;
        }
        var codes = _model.Elements.Select(e => e.Code).ToList();
        var index = codes.IndexOf(elementCode);
        var target = index + delta;
        if (index < 0 || target < 0 || target >= codes.Count)
        {
            return;
        }
        (codes[index], codes[target]) = (codes[target], codes[index]);
        try
        {
            await ElementAuthoringService.ReorderElementsAsync(ModelCode, codes);
            await ReloadAsync();
        }
        catch (Exception ex) when (ex is InvalidOperationException or StructureFrozenException)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
