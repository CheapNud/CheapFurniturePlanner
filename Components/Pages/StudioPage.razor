@page "/studio"
@using CheapFurniturePlanner.Catalogue
@using CheapFurniturePlanner.Domain.Catalog

@inject ModelPublishService ModelPublishService
@inject ModelAuthoringService ModelAuthoringService
@inject AuthoringCatalogueStore AuthoringCatalogueStore
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>Catalog Studio - Cheap Furniture Planner</PageTitle>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h5">Catalog Studio</MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => OpenNewModelDialogAsync())">
                New model
            </MudButton>
        </MudStack>
        <MudAlert Severity="Severity.Info">Only released (Active) models appear in the catalogue and planner.</MudAlert>
    </MudStack>
</MudPaper>

@if (_models is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTable Items="@_models" Hover="true" Striped="true" Dense="true" Elevation="2">
        <HeaderContent>
            <MudTh>Code</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>State</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Code">@context.Code</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="State">
                <MudChip T="string" Size="Size.Small" Color="@StateColor(context.State)">@context.State</MudChip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudButton Size="Size.Small"
                               Variant="Variant.Outlined"
                               Color="Color.Info"
                               OnClick="@(() => Navigation.NavigateTo($"/studio/{context.Code}"))">
                        Name variants
                    </MudButton>
                    <MudButton Size="Size.Small"
                               Variant="Variant.Outlined"
                               Color="Color.Info"
                               OnClick="@(() => Navigation.NavigateTo($"/studio/{context.Code}/elements"))">
                        Elements
                    </MudButton>
                    <MudSelect T="TradeItemState"
                               Label="State"
                               Dense="true"
                               Margin="Margin.Dense"
                               Value="@context.State"
                               ValueChanged="@((TradeItemState newState) => ChangeStateAsync(context.Code, newState))">
                        @foreach (var state in Enum.GetValues<TradeItemState>())
                        {
                            <MudSelectItem T="TradeItemState" Value="@state">@state</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Size="Size.Small"
                               Variant="Variant.Outlined"
                               Color="Color.Default"
                               OnClick="@(() => OpenEditModelDialogAsync(context.Code))">
                        Edit
                    </MudButton>
                    <MudButton Size="Size.Small"
                               Variant="Variant.Outlined"
                               Color="Color.Error"
                               Disabled="@(context.State == TradeItemState.Active)"
                               OnClick="@(() => DeleteModelAsync(context.Code))">
                        Delete
                    </MudButton>
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private IReadOnlyList<AuthoringModel>? _models;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _models = await ModelPublishService.GetAuthoringModelsAsync();
    }

    // Free-flow state change: always reload afterwards, whether SetStateAsync succeeded or reverted -
    // that's how the row ends up showing the model's ACTUAL persisted state either way.
    private async Task ChangeStateAsync(string modelCode, TradeItemState newState)
    {
        try
        {
            await ModelPublishService.SetStateAsync(modelCode, newState);
            Snackbar.Add($"Model '{modelCode}' set to {newState}.", Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        await ReloadAsync();
    }

    private async Task OpenNewModelDialogAsync()
    {
        var existingCodes = (_models ?? []).Select(model => model.Code).ToList();
        var parameters = new DialogParameters<NewModelDialog>
        {
            { dialog => dialog.ExistingCodes, existingCodes }
        };
        var dialogRef = await DialogService.ShowAsync<NewModelDialog>("New model", parameters);
        var dialogResult = await dialogRef.Result;
        if (dialogResult is { Canceled: false })
        {
            await ReloadAsync();
        }
    }

    private async Task OpenEditModelDialogAsync(string modelCode)
    {
        var model = await AuthoringCatalogueStore.LoadModelAsync(modelCode);
        if (model is null)
        {
            Snackbar.Add($"Model '{modelCode}' not found.", Severity.Error);
            return;
        }

        var parameters = new DialogParameters<EditModelDialog>
        {
            { dialog => dialog.Code, model.Code },
            { dialog => dialog.Name, model.Name },
            { dialog => dialog.Collection, model.CollectionCode },
            { dialog => dialog.ModelType, model.ModelTypeCode }
        };
        var dialogRef = await DialogService.ShowAsync<EditModelDialog>("Edit model", parameters);
        var dialogResult = await dialogRef.Result;
        if (dialogResult is { Canceled: false })
        {
            await ReloadAsync();
        }
    }

    private async Task DeleteModelAsync(string modelCode)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete model",
            $"'{modelCode}' will be permanently deleted. Continue?",
            yesText: "Delete",
            cancelText: "Cancel");
        if (confirmed != true)
        {
            return;
        }

        try
        {
            await ModelAuthoringService.DeleteAsync(modelCode);
            Snackbar.Add($"Model '{modelCode}' deleted.", Severity.Success);
            await ReloadAsync();
        }
        catch (ModelActiveException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private static Color StateColor(TradeItemState state) => state switch
    {
        TradeItemState.Active => Color.Success,
        TradeItemState.Discontinued => Color.Error,
        TradeItemState.PhasingOut => Color.Warning,
        _ => Color.Default
    };
}
